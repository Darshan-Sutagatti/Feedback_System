<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- LOGIN -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- REGISTER -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>servlet.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- ADD TEACHER -->
    <servlet>
        <servlet-name>AddTeacherServlet</servlet-name>
        <servlet-class>servlet.AddTeacherServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddTeacherServlet</servlet-name>
        <url-pattern>/AddTeacherServlet</url-pattern>
    </servlet-mapping>

    <!-- DELETE TEACHER -->
    <servlet>
        <servlet-name>DeleteTeacherServlet</servlet-name>
        <servlet-class>servlet.DeleteTeacherServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DeleteTeacherServlet</servlet-name>
        <url-pattern>/DeleteTeacherServlet</url-pattern>
    </servlet-mapping>

    <!-- ADD FEEDBACK -->
    <servlet>
        <servlet-name>AddFeedbackServlet</servlet-name>
        <servlet-class>servlet.AddFeedbackServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddFeedbackServlet</servlet-name>
        <url-pattern>/AddFeedbackServlet</url-pattern>
    </servlet-mapping>

    <!-- DELETE FEEDBACK -->
    <servlet>
        <servlet-name>DeleteFeedbackServlet</servlet-name>
        <servlet-class>servlet.DeleteFeedbackServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DeleteFeedbackServlet</servlet-name>
        <url-pattern>/DeleteFeedbackServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
    <servlet-name>ViewFeedbackServlet</servlet-name>
    <servlet-class>servlet.ViewFeedbackServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ViewFeedbackServlet</servlet-name>
    <url-pattern>/ViewFeedbackServlet</url-pattern>
</servlet-mapping>

</web-app>